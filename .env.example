# Database (PostgreSQL via Docker)
DATABASE_URL=postgres://tinystore:tinystore@localhost:5432/tinystore

# Redis (for cache + queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Queue adapter: 'memory' (default, no Redis) or 'bullmq' (requires Redis)
QUEUE_ADAPTER=bullmq

# Cache adapter: 'memory' (default, no Redis) or 'redis' (requires Redis)
CACHE_ADAPTER=redis
