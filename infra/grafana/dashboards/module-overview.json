  "description": "Per-module SLI overview for Tiny Store. Displays request rate, error rate, and p95 latency for orders, inventory, payments, and shipments.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Orders",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "orders — request rate",
      "id": 1,
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "targets": [
        { "expr": "sum(rate(orders_requests_total[5m]))", "legendFormat": "req/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "orders — error rate",
      "id": 2,
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "expr": "sum(rate(orders_errors_total[5m])) / sum(rate(orders_requests_total[5m]))", "legendFormat": "error %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "orders — p95 latency",
      "id": 3,
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(orders_latency_bucket[5m])))", "legendFormat": "p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
